## t/test_azure.stk — assertion tests for the stryke `Azure` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_azure.{dylib,so}` on `use Azure`.
##
## Service-dependent assertions only fire when:
##   * an Entra credential is reachable (identity_token succeeds), AND
##   * the relevant account/vault + $STRYKE_AZURE_TEST_* env var is set.
## The permission-free assertions (version + cdylib loaded) always run, so
## CI without Azure access still exercises the FFI surface.
##
## Env vars consumed:
##   AZURE_STORAGE_ACCOUNT          + STRYKE_AZURE_TEST_CONTAINER  (Blob)
##   AZURE_STORAGE_ACCOUNT          + STRYKE_AZURE_TEST_QUEUE      (Queue)
##   AZURE_COSMOS_ACCOUNT           + STRYKE_AZURE_TEST_COSMOS_DB
##                                  + STRYKE_AZURE_TEST_COSMOS_CONTAINER  (Cosmos)
##   AZURE_KEYVAULT_NAME                                          (Secrets)

use Azure
use Azure::Blob
use Azure::Queue
use Azure::Cosmos
use Azure::Secrets

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Azure::version()
assert_ok $version, "Azure::version returns truthy (cdylib loaded)"

# ── credential probe ────────────────────────────────────────────────
val $tok = eval { Azure::identity_token() }
val $have_creds = !$@ && defined $tok && $tok->{acquired}

if ($have_creds) {
    assert_ok defined $tok->{expires_on}, "identity_token returns expires_on"
    assert_ok Azure::ping(), "ping returns truthy when creds present"

    # ── Blob round-trip (AZURE_STORAGE_ACCOUNT + STRYKE_AZURE_TEST_CONTAINER) ──
    val $acct = $ENV{AZURE_STORAGE_ACCOUNT}
    val $container = $ENV{STRYKE_AZURE_TEST_CONTAINER}
    if (defined $acct && defined $container) {
        val $name = "stryke-azure-test/$$/" . time() . ".txt"
        val $uri = "az://$container/$name"
        val $body = "hello-from-stryke-azure-$$"

        assert_ok Azure::Blob::put($uri, data => $body, account => $acct),
            "blob put returns truthy"
        assert_eq Azure::Blob::get($uri, account => $acct), $body,
            "blob get round-trip"
        assert_eq Azure::Blob::head($uri, account => $acct)->{content_length}, len($body),
            "blob head content_length matches body"
        val @ls = Azure::Blob::ls("az://$container/stryke-azure-test/$$/", account => $acct)
        assert_ge scalar(@ls), 1, "blob ls finds at least our object"
        Azure::Blob::rm($uri, account => $acct)
        assert_ok 1, "blob rm completed without dying"
    }

    # ── Queue round-trip (AZURE_STORAGE_ACCOUNT + STRYKE_AZURE_TEST_QUEUE) ──
    val $queue = $ENV{STRYKE_AZURE_TEST_QUEUE}
    if (defined $acct && defined $queue) {
        val $msg = "msg-from-stryke-azure-$$-" . time()
        Azure::Queue::send($queue, $msg, account => $acct)
        assert_ok 1, "queue send completed without dying"
        val @msgs = Azure::Queue::receive($queue, max => 5, account => $acct)
        var $found
        for val $m (@msgs) {
            if ($m->{body} eq $msg) {
                $found = $m
                last
            }
        }
        assert_ok defined $found, "queue receive finds our body"
        if (defined $found) {
            Azure::Queue::delete($queue, $found->{message_id}, $found->{pop_receipt}, account => $acct)
            assert_ok 1, "queue delete completed without dying"
        }
    }

    # ── Cosmos round-trip (AZURE_COSMOS_ACCOUNT + DB + CONTAINER) ──
    # The target container's partition-key path must be `/pk`.
    val $cacct = $ENV{AZURE_COSMOS_ACCOUNT}
    val $cdb = $ENV{STRYKE_AZURE_TEST_COSMOS_DB}
    val $ccoll = $ENV{STRYKE_AZURE_TEST_COSMOS_CONTAINER}
    if (defined $cacct && defined $cdb && defined $ccoll) {
        val $pk = "stryke-azure-test"
        val $id = "item-$$-" . time()
        val $item = { id => $id, pk => $pk, name => "ada", n => 42 }

        val $put = Azure::Cosmos::put($cdb, $ccoll, $pk, $item, account => $cacct)
        assert_eq $put->{name}, "ada", "cosmos put round-trip name"
        val $got = Azure::Cosmos::get($cdb, $ccoll, $pk, $id, account => $cacct)
        assert_eq $got->{n}, 42, "cosmos get round-trip n"
        Azure::Cosmos::delete($cdb, $ccoll, $pk, $id, account => $cacct)
        assert_ok 1, "cosmos delete completed without dying"
    }

    # ── Key Vault Secrets round-trip (AZURE_KEYVAULT_NAME) ──
    val $vault = $ENV{AZURE_KEYVAULT_NAME}
    if (defined $vault) {
        val $sname = "stryke-azure-test-$$"
        val $sval = "secret-$$-" . time()

        val $set = Azure::Secrets::set($sname, $sval, vault => $vault)
        assert_ok defined $set->{id}, "secrets set returns id"
        assert_eq Azure::Secrets::get($sname, vault => $vault), $sval,
            "secrets get round-trip"
        Azure::Secrets::rm($sname, vault => $vault)
        assert_ok 1, "secrets delete completed without dying"
    }
}

# ── pure helpers (no Azure — always run) ─────────────────────────────
val $rid = Azure::parse_resource_id("/subscriptions/abc-123/resourceGroups/my-rg/providers/Microsoft.Storage/storageAccounts/mystore")
assert_eq $rid->{subscription},   "abc-123",           "parse_resource_id: subscription"
assert_eq $rid->{resource_group}, "my-rg",             "parse_resource_id: resource group"
assert_eq $rid->{provider},       "Microsoft.Storage", "parse_resource_id: provider"
assert_eq $rid->{resource_type},  "storageAccounts",   "parse_resource_id: type"
assert_eq $rid->{name},           "mystore",           "parse_resource_id: name"

# build_resource_id: inverse of parse_resource_id, canonical ARM casing.
assert_eq Azure::build_resource_id(subscription => "abc-123", resource_group => "my-rg", provider => "Microsoft.Storage", types => [{ type => "storageAccounts", name => "mystore" }]), "/subscriptions/abc-123/resourceGroups/my-rg/providers/Microsoft.Storage/storageAccounts/mystore", "build_resource_id: full path"
assert_eq Azure::build_resource_id(subscription => "s"), "/subscriptions/s", "build_resource_id: subscription only"
assert_eq Azure::build_resource_id(subscription => $rid->{subscription}, resource_group => $rid->{resource_group}, provider => $rid->{provider}, types => $rid->{types}), "/subscriptions/abc-123/resourceGroups/my-rg/providers/Microsoft.Storage/storageAccounts/mystore", "build_resource_id: round-trips parse_resource_id"
assert_dies fn { Azure::build_resource_id(types => [{ type => "x", name => "y" }]) }, "build_resource_id: types without provider errors"

val $cs = Azure::parse_connection_string("DefaultEndpointsProtocol=https;AccountName=mystore;AccountKey=Zm9vYmF6==;EndpointSuffix=core.windows.net")
assert_eq $cs->{pairs}{AccountName}, "mystore",        "parse_connection_string: account name"
assert_eq $cs->{pairs}{AccountKey},  "Zm9vYmF6==",     "parse_connection_string: base64 key survives"

# build_connection_string: inverse of parse_connection_string (byte-identical round-trip).
val $built = Azure::build_connection_string(%{ $cs->{pairs} })
assert_eq $built, "DefaultEndpointsProtocol=https;AccountName=mystore;AccountKey=Zm9vYmF6==;EndpointSuffix=core.windows.net", "build_connection_string: round-trips parse byte-identically (order + base64 ==)"
assert_dies fn { Azure::build_connection_string(K => "a;b") }, "build_connection_string: rejects ';' in a value"

# parse_blob_uri: account/service/container/nested-blob from the endpoint URL.
val $bu = Azure::parse_blob_uri("https://mystore.blob.core.windows.net/images/2025/cat.png")
assert_eq $bu->{account},   "mystore",      "parse_blob_uri: account"
assert_eq $bu->{service},   "blob",         "parse_blob_uri: service"
assert_eq $bu->{container}, "images",       "parse_blob_uri: container"
assert_eq $bu->{blob},      "2025/cat.png", "parse_blob_uri: nested blob path kept"
val $dfs = Azure::parse_blob_uri("https://lake.dfs.core.windows.net/fs")
assert_eq $dfs->{service}, "dfs",            "parse_blob_uri: ADLS Gen2 dfs service"
assert_ok !defined($dfs->{blob}),            "parse_blob_uri: container-only URL has undef blob"

# build_blob_uri: inverse of parse_blob_uri.
assert_eq Azure::build_blob_uri(account => "mystore", container => "images", blob => "2025/cat.png"), "https://mystore.blob.core.windows.net/images/2025/cat.png", "build_blob_uri: full endpoint URL"
assert_eq Azure::build_blob_uri(account => "lake", service => "dfs", container => "fs"), "https://lake.dfs.core.windows.net/fs", "build_blob_uri: dfs service"
assert_eq Azure::build_blob_uri(account => "acct"), "https://acct.blob.core.windows.net", "build_blob_uri: account-only endpoint"
assert_dies fn { Azure::build_blob_uri(container => "c") }, "build_blob_uri: missing account errors"

# storage_endpoint: service endpoint with sovereign-cloud suffixes.
assert_eq Azure::storage_endpoint(account => "mystore")->{endpoint}, "mystore.blob.core.windows.net", "storage_endpoint: public default"
assert_eq Azure::storage_endpoint(account => "acct", service => "queue")->{endpoint}, "acct.queue.core.windows.net", "storage_endpoint: per-service"
assert_eq Azure::storage_endpoint(account => "acct", cloud => "china")->{endpoint}, "acct.blob.core.chinacloudapi.cn", "storage_endpoint: China suffix"
assert_eq Azure::storage_endpoint(account => "acct", service => "table", cloud => "usgov")->{endpoint}, "acct.table.core.usgovcloudapi.net", "storage_endpoint: US Gov suffix"
assert_dies fn { Azure::storage_endpoint(account => "a", cloud => "mars") }, "storage_endpoint: rejects an unknown cloud"

# parse_storage_endpoint: inverse of storage_endpoint.
val $pe = Azure::parse_storage_endpoint("mystore.blob.core.windows.net")
assert_eq $pe->{account}, "mystore", "parse_storage_endpoint: account extracted"
assert_eq $pe->{service}, "blob",    "parse_storage_endpoint: service extracted"
assert_eq $pe->{cloud},   "public",  "parse_storage_endpoint: suffix → public cloud"
# Full URL with a path resolves to the same host.
assert_eq Azure::parse_storage_endpoint("https://acct.queue.core.windows.net/q/messages")->{service}, "queue", "parse_storage_endpoint: strips scheme + path"
# Sovereign clouds map back.
assert_eq Azure::parse_storage_endpoint("acct.table.core.usgovcloudapi.net")->{cloud}, "usgov", "parse_storage_endpoint: US Gov cloud"
# Round-trips storage_endpoint.
assert_eq Azure::parse_storage_endpoint(Azure::storage_endpoint(account => "acct", service => "table", cloud => "china")->{endpoint})->{cloud}, "china", "parse_storage_endpoint: round-trips storage_endpoint"
assert_dies fn { Azure::parse_storage_endpoint("acct.bogus.core.windows.net") }, "parse_storage_endpoint: rejects an unknown service"

assert_ok Azure::valid_storage_account_name("mystore123")->{valid}, "valid_storage_account_name: legal"
assert_eq Azure::valid_storage_account_name("My-Store")->{valid}, 0, "valid_storage_account_name: rejects upper+hyphen"

assert_ok Azure::valid_container_name("my-logs-2025")->{valid}, "valid_container_name: legal"
val $cn = Azure::valid_container_name("a--b")
assert_eq $cn->{valid}, 0, "valid_container_name: rejects consecutive hyphens"
assert_match qr/consecutive/, $cn->{reason}, "valid_container_name: reason names the rule"

# valid_table_name: ^[A-Za-z][A-Za-z0-9]{2,62}$, "tables" reserved.
assert_ok Azure::valid_table_name("MyTable")->{valid},     "valid_table_name: alphanumeric, letter start"
assert_eq Azure::valid_table_name("1table")->{valid}, 0,   "valid_table_name: rejects digit start"
assert_eq Azure::valid_table_name("my-table")->{valid}, 0, "valid_table_name: rejects hyphen (unlike container)"
assert_eq Azure::valid_table_name("ab")->{valid}, 0,       "valid_table_name: under 3 chars fails"
val $tr = Azure::valid_table_name("Tables")
assert_eq $tr->{valid}, 0,                                 "valid_table_name: 'tables' reserved (case-insensitive)"
assert_match qr/reserved/, $tr->{reason},                  "valid_table_name: reason names the reservation"
assert_ok Azure::valid_table_name("tablesx")->{valid},     "valid_table_name: a name containing 'tables' is fine"

# valid_cosmos_id: Cosmos DB database/container id — ≤255, no / or \.
assert_ok Azure::valid_cosmos_id("my-database")->{valid},   "valid_cosmos_id: hyphens/letters ok"
assert_ok Azure::valid_cosmos_id("Orders.2025_v2")->{valid}, "valid_cosmos_id: dots/underscores ok"
assert_eq Azure::valid_cosmos_id("a/b")->{valid}, 0,        "valid_cosmos_id: forward slash forbidden"
assert_eq Azure::valid_cosmos_id("a\\b")->{valid}, 0,       "valid_cosmos_id: backslash forbidden"
assert_eq Azure::valid_cosmos_id("")->{valid}, 0,           "valid_cosmos_id: empty rejected"
assert_dies fn { Azure::valid_cosmos_id() }, "valid_cosmos_id: dies on missing id"

# valid_guid: Azure GUID 8-4-4-4-12 hex form.
assert_ok Azure::valid_guid("3f2504e0-4f89-41d3-9a0c-0305e82c3301")->{valid}, "valid_guid: canonical GUID"
assert_ok Azure::valid_guid("3F2504E0-4F89-41D3-9A0C-0305E82C3301")->{valid}, "valid_guid: uppercase hex"
assert_eq Azure::valid_guid("3f2504e0-4f89-41d3-9a0c-0305e82c330")->{valid}, 0, "valid_guid: wrong length fails"
assert_eq Azure::valid_guid("3g2504e0-4f89-41d3-9a0c-0305e82c3301")->{valid}, 0, "valid_guid: non-hex fails"
val $bg = Azure::valid_guid("{3f2504e0-4f89-41d3-9a0c-0305e82c3301}")
assert_eq $bg->{valid}, 0,                "valid_guid: braces not accepted"
assert_match qr/36 characters/, $bg->{reason}, "valid_guid: reason names the length"

# normalize_guid: canonicalize Azure GUID formats to lowercase 8-4-4-4-12.
val $canon = "3f2504e0-4f89-41d3-9a0c-0305e82c3301"
assert_eq Azure::normalize_guid($canon),                                  $canon, "normalize_guid: already canonical"
assert_eq Azure::normalize_guid("3F2504E0-4F89-41D3-9A0C-0305E82C3301"),  $canon, "normalize_guid: lowercases"
assert_eq Azure::normalize_guid("{3f2504e0-4f89-41d3-9a0c-0305e82c3301}"), $canon, "normalize_guid: strips braces"
assert_eq Azure::normalize_guid("3f2504e04f8941d39a0c0305e82c3301"),      $canon, "normalize_guid: re-groups hyphenless"
assert_dies fn { Azure::normalize_guid("3f2504e0") }, "normalize_guid: rejects too few hex digits"

# format_guid: re-emit in a .NET format specifier (N/D/B/P).
assert_eq Azure::format_guid($canon, "N"), "3f2504e04f8941d39a0c0305e82c3301", "format_guid: N drops the hyphens"
assert_eq Azure::format_guid($canon, "D"), $canon,                             "format_guid: D is the hyphenated form"
assert_eq Azure::format_guid($canon, "B"), "{$canon}",                         "format_guid: B wraps in braces"
assert_eq Azure::format_guid($canon, "P"), "($canon)",                         "format_guid: P wraps in parens"
assert_eq Azure::format_guid("{3F2504E0-4F89-41D3-9A0C-0305E82C3301}", "n"), "3f2504e04f8941d39a0c0305e82c3301", "format_guid: case-insensitive specifier, any input form"
assert_eq Azure::format_guid($canon), $canon, "format_guid: defaults to D"
assert_dies fn { Azure::format_guid($canon, "X") }, "format_guid: rejects the unsupported X specifier"

test_run
