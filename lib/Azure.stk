    die "Azure::blob_set_metadata: metadata must be hashref" unless ref($metadata) eq "HASH"
    val $r = Azure::_req({ container => $container, name => $name, metadata => $metadata }, \%opts)
    Azure::_decode("blob_set_metadata", azure__blob_set_metadata(to_json($r)))->{metadata}
}

## Delete a Cosmos database. Returns 1 on success.
fn Azure::cosmos_delete_database ($database, %opts) {
    val $r = Azure::_req({ database => $database }, \%opts)
    Azure::_decode("cosmos_delete_database", azure__cosmos_delete_database(to_json($r)))->{deleted} ? 1 : 0
}

## Delete a Cosmos container. Returns 1 on success.
fn Azure::cosmos_delete_container ($database, $container, %opts) {
    val $r = Azure::_req({ database => $database, container => $container }, \%opts)
    Azure::_decode("cosmos_delete_container", azure__cosmos_delete_container(to_json($r)))->{deleted} ? 1 : 0
}

## Replace an existing Cosmos item (fails if it doesn't exist). Returns the item.
fn Azure::cosmos_replace_item ($database, $container, $pk, $id, $item, %opts) {
    die "Azure::cosmos_replace_item: item must be hashref" unless ref($item) eq "HASH"
    val $r = Azure::_req(
        { database => $database, container => $container,
          partition_key => $pk, id => $id, item => $item }, \%opts)
    Azure::_decode("cosmos_replace_item", azure__cosmos_replace_item(to_json($r)))->{item}
}

# ── secret versions + backup ─────────────────────────────────────────

## List a secret's versions ({ id }). Newest first.
fn Azure::secrets_list_versions ($name, %opts) {
    val $r = Azure::_req({ name => $name }, \%opts)
    @{ Azure::_decode("secrets_list_versions", azure__secrets_list_versions(to_json($r)))->{versions} }
}

## Back up a secret; returns the base64 backup blob (restore in the same vault).
fn Azure::secrets_backup ($name, %opts) {
    val $r = Azure::_req({ name => $name }, \%opts)
    Azure::_decode("secrets_backup", azure__secrets_backup(to_json($r)))->{backup}
}

# ── Key Vault Keys (crypto) ──────────────────────────────────────────

## Encrypt $plaintext with key $key. opts: algorithm (RSA-OAEP-256 default).
## Returns { ciphertext (base64), kid, algorithm }.
fn Azure::keys_encrypt ($key, $plaintext, %opts) {
    val $r = Azure::_req(
        { key => $key, plaintext => $plaintext, algorithm => $opts{algorithm} }, \%opts)
    Azure::_decode("keys_encrypt", azure__keys_encrypt(to_json($r)))
}

## Decrypt base64 $ciphertext with key $key version $version (the trailing
## segment of the encrypt result's kid). opts: algorithm. Returns the plaintext.
fn Azure::keys_decrypt ($key, $version, $ciphertext, %opts) {
    val $r = Azure::_req(
        { key => $key, version => $version, ciphertext => $ciphertext,
          algorithm => $opts{algorithm} }, \%opts)
    Azure::_decode("keys_decrypt", azure__keys_decrypt(to_json($r)))->{plaintext}
}

## List key identifiers in the vault. Returns a list of { kid } hashrefs.
fn Azure::keys_list (%opts) {
    @{ Azure::_decode("keys_list",
        azure__keys_list(to_json(Azure::_req({}, \%opts))))->{keys} }
}

## Get a key's public material by name. Returns { key, jwk, managed } where jwk
## is the JSON Web Key (kid, kty, key ops, public components).
fn Azure::keys_get ($key, %opts) {
    val $r = Azure::_req({ key => $key }, \%opts)
    Azure::_decode("keys_get", azure__keys_get(to_json($r)))
}

# ── Azure Resource Manager helpers ───────────────────────────────────
# The management-plane ops (Resource Groups, Compute, Storage Accounts,
# Service Bus, Monitor, Container Instances, AKS) reach ARM via REST using
# the same shared Entra credential. They take a subscription from the
# `subscription =>` opt (or AZURE_SUBSCRIPTION_ID) and, where scoped, a
# `resource_group =>` opt.

## Merge management opts (subscription/resource_group/arm_endpoint) into a request.
fn Azure::_arm_req ($extra, $opts) {
    var %r = %$extra
    for val $k (qw(subscription resource_group arm_endpoint)) {
        $r{$k} = $opts->{$k} if exists $opts->{$k} && defined $opts->{$k}
    }
    \%r
}

# ── Resource Groups ──────────────────────────────────────────────────

## List resource groups in the subscription. Returns a list of group hashrefs.
fn Azure::resource_groups_list (%opts) {
    @{ Azure::_decode("resource_groups_list",
        azure__resource_groups_list(to_json(Azure::_arm_req({}, \%opts))))->{resource_groups} }
}

## Get a resource group by name (`resource_group =>` opt). Returns the hashref.
fn Azure::resource_group_get (%opts) {
    Azure::_decode("resource_group_get",
        azure__resource_group_get(to_json(Azure::_arm_req({}, \%opts))))
}

## Create/update a resource group. opts: resource_group, location (required).
## Returns the group hashref.
fn Azure::resource_group_create ($resource_group, $location, %opts) {
    val $r = Azure::_arm_req({ resource_group => $resource_group, location => $location }, \%opts)
    Azure::_decode("resource_group_create", azure__resource_group_create(to_json($r)))
}

## Delete a resource group (long-running). Returns { resource_group, deleting }.
fn Azure::resource_group_delete ($resource_group, %opts) {
    val $r = Azure::_arm_req({ resource_group => $resource_group }, \%opts)
    Azure::_decode("resource_group_delete", azure__resource_group_delete(to_json($r)))
}

