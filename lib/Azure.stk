fn Azure::vm_list (%opts) {
    @{ Azure::_decode("vm_list",
        azure__vm_list(to_json(Azure::_arm_req({}, \%opts))))->{vms} }
}

## Get a VM by name (`vm =>`, `resource_group =>` opts). Returns the hashref.
fn Azure::vm_get ($vm, %opts) {
    val $r = Azure::_arm_req({ vm => $vm }, \%opts)
    Azure::_decode("vm_get", azure__vm_get(to_json($r)))
}

## Start a VM (long-running). Returns { vm, action, accepted }.
fn Azure::vm_start ($vm, %opts) {
    Azure::_decode("vm_start", azure__vm_start(to_json(Azure::_arm_req({ vm => $vm }, \%opts))))
}

## Power off a VM but keep it allocated (still billed). Returns { vm, action, accepted }.
fn Azure::vm_stop ($vm, %opts) {
    Azure::_decode("vm_stop", azure__vm_stop(to_json(Azure::_arm_req({ vm => $vm }, \%opts))))
}

## Deallocate a VM (stop and release compute, no compute charge). Returns the hashref.
fn Azure::vm_deallocate ($vm, %opts) {
    Azure::_decode("vm_deallocate", azure__vm_deallocate(to_json(Azure::_arm_req({ vm => $vm }, \%opts))))
}

## Restart a VM (long-running). Returns { vm, action, accepted }.
fn Azure::vm_restart ($vm, %opts) {
    Azure::_decode("vm_restart", azure__vm_restart(to_json(Azure::_arm_req({ vm => $vm }, \%opts))))
}

## Get a VM's runtime instance view (`vm =>`, `resource_group =>` opts). Returns
## { vm, power_state, instance_view } — power_state is the PowerState code
## (running/stopped/deallocated) lifted out of the statuses array.
fn Azure::vm_instance_view ($vm, %opts) {
    Azure::_decode("vm_instance_view", azure__vm_instance_view(to_json(Azure::_arm_req({ vm => $vm }, \%opts))))
}

## List Microsoft.Compute SKUs (VM sizes etc.) for the subscription, optionally
## narrowed to one region by a `location =>` opt. Returns a list of SKU hashrefs.
fn Azure::compute_skus (%opts) {
    @{ Azure::_decode("compute_skus",
        azure__compute_skus(to_json(Azure::_arm_req({ location => $opts{location} }, \%opts))))->{skus} }
}

