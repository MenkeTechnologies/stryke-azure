# ── Subscriptions + locations + generic resources ────────────────────

## List every subscription the credential can see (tenant scope — no
## subscription opt). Returns a list of subscription hashrefs.
fn Azure::subscriptions_list (%opts) {
    @{ Azure::_decode("subscriptions_list",
        azure__subscriptions_list(to_json(Azure::_arm_req({}, \%opts))))->{subscriptions} }
}

## List the Azure regions available to the subscription. Returns a list of
## location hashrefs ({ name, displayName, … }).
fn Azure::locations_list (%opts) {
    @{ Azure::_decode("locations_list",
        azure__locations_list(to_json(Azure::_arm_req({}, \%opts))))->{locations} }
}

## List resources in the subscription, optionally scoped by `resource_group =>`
## and filtered by an ARM `filter =>` opt (e.g.
## "resourceType eq 'Microsoft.Storage/storageAccounts'"). Returns a list of
## resource hashrefs.
fn Azure::resources_list (%opts) {
    @{ Azure::_decode("resources_list",
        azure__resources_list(to_json(Azure::_arm_req({ filter => $opts{filter} }, \%opts))))->{resources} }
}

# ── pure helpers (no Azure) ───────────────────────────────────────────

## Parse an Azure resource ID into a hashref { subscription, resource_group,
## provider, types => [{ type, name }], resource_type, name }. resource_type/
## name are the last type/name pair.
fn Azure::parse_resource_id ($id) {
    Azure::_decode("parse_resource_id", azure__parse_resource_id(to_json({ id => $id })))
}

## The parent scope of an Azure resource ID — the RBAC-scope "dirname". The
## hierarchy is resource → resource-group scope → subscription → tenant root, with
## the providers/{namespace} marker handled correctly. A nested resource drops its
## last type/name pair; a top-level resource collapses to its resource-group (or
## subscription) scope; a resource group's parent is its subscription; a
## subscription has an empty parent. Returns a hashref { id, parent, has_parent }.
fn Azure::resource_id_parent ($id) {
    Azure::_decode("resource_id_parent", azure__resource_id_parent(to_json({ id => $id })))
}

## Assemble an Azure resource ID from parts, emitting canonical ARM casing.
## %opts: subscription, resource_group, provider, types => [{ type, name }].
## Inverse of parse_resource_id. Returns the id string.
fn Azure::build_resource_id (%opts) {
    Azure::_decode("build_resource_id", azure__build_resource_id(to_json(\%opts)))->{id}
}

## Parse an Azure connection string "Key=Value;Key=Value…" into a hashref of
## { pairs => { Key => Value } }. Values keep everything after the first "=",
## so a base64 AccountKey survives.
fn Azure::parse_connection_string ($cs) {
    Azure::_decode("parse_connection_string",
        azure__parse_connection_string(to_json({ connection_string => $cs })))
}

## Assemble an Azure connection string "Key=Value;…" from a %pairs hashref —
## inverse of parse_connection_string. Keys keep their order so a parsed string
## rebuilds byte-identically; values may contain "=" but not ";". Returns the
## connection string.
fn Azure::build_connection_string (%pairs) {
    Azure::_decode("build_connection_string",
        azure__build_connection_string(to_json({ pairs => \%pairs })))->{connection_string}
}

## Mask the secret fields of a connection $cs so it can be safely logged — the
## value of every AccountKey and SharedAccessSignature pair (case-insensitive)
## becomes a mask (%opts mask, default "***"); all other pairs are preserved.
## Returns a hashref { redacted, masked_count }.
fn Azure::redact_connection_string ($cs, %opts) {
    Azure::_decode("redact_connection_string",
        azure__redact_connection_string(to_json({ connection_string => $cs, mask => $opts{mask} })))
}

## Parse an Azure storage blob endpoint URL
## "https://<account>.<service>.core.windows.net/<container>/<blob>" into a
## hashref { account, service, host, container, blob }. service is one of blob,
## dfs, queue, table, file. container/blob are undef when the URL stops short.
fn Azure::parse_blob_uri ($uri) {
    Azure::_decode("parse_blob_uri", azure__parse_blob_uri(to_json({ uri => $uri })))
}

## Build an Azure storage blob endpoint URL from parts — inverse of
## parse_blob_uri. %opts: account (required), service (default "blob"; one of
## blob/dfs/queue/table/file), container, blob. Returns the URL string.
fn Azure::build_blob_uri (%opts) {
    Azure::_decode("build_blob_uri", azure__build_blob_uri(to_json(\%opts)))->{uri}
}

## Build a storage service endpoint <account>.<service>.<suffix> with
## sovereign-cloud awareness (what build_blob_uri's hardwired core.windows.net
## can't reach). %opts: account (required), service (default "blob"), cloud
## (default "public"; public/china/usgov). Returns { account, service, cloud,
## suffix, endpoint, url }.
fn Azure::storage_endpoint (%opts) {
    Azure::_decode("storage_endpoint", azure__storage_endpoint(to_json(\%opts)))
}

## Parse a storage endpoint back into its parts — inverse of storage_endpoint.
## $endpoint may be a bare host (acct.blob.core.windows.net) or a full URL (scheme
## and path stripped). The service is validated (blob/dfs/queue/table/file) and the
## suffix mapped to its canonical cloud (public/china/usgov). Returns a hashref
## { endpoint, account, service, cloud, suffix, url }.
fn Azure::parse_storage_endpoint ($endpoint) {
    Azure::_decode("parse_storage_endpoint", azure__parse_storage_endpoint(to_json({ endpoint => $endpoint })))
}

## Validate a storage account name (3-24 lowercase letters/numbers). Returns
## { name, valid, reason }.
fn Azure::valid_storage_account_name ($name) {
    Azure::_decode("valid_storage_account_name",
        azure__valid_storage_account_name(to_json({ name => $name })))
}

## Validate a Blob container name (3-63 chars of [a-z0-9-], start alphanumeric,
## no consecutive/trailing hyphens). Returns { name, valid, reason }.
fn Azure::valid_container_name ($name) {
    Azure::_decode("valid_container_name",
        azure__valid_container_name(to_json({ name => $name })))
}

## Validate a Blob name per the Blob service rules: 1-1024 characters,
## case-sensitive, at most 254 `/`-delimited path segments, and must not end with
## a dot or a forward slash. The blob-path member of the valid_* family (pairs
## with parse_blob_uri/build_blob_uri). Returns { name, valid, reason,
## characters, segments }.
fn Azure::valid_blob_name ($name) {
    Azure::_decode("valid_blob_name",
        azure__valid_blob_name(to_json({ name => $name })))
}

## Validate an Azure Key Vault secret name per the Key Vault object-identifier
## rules: 1-127 characters of alphanumeric characters and hyphens only (no
## underscores or dots). The Key Vault member of the valid_* family. Returns a
## hashref { name, valid, reason } (reason undef when valid).
fn Azure::valid_keyvault_secret_name ($name) {
    Azure::_decode("valid_keyvault_secret_name",
        azure__valid_keyvault_secret_name(to_json({ name => $name })))
}

## Validate an Azure Storage queue name: 3-63 chars of lowercase letters,
## numbers and hyphens, starting alphanumeric, no consecutive/trailing hyphens
## (same DNS-label grammar as a container). Returns { name, valid, reason }.
fn Azure::valid_queue_name ($name) {
    Azure::_decode("valid_queue_name",
        azure__valid_queue_name(to_json({ name => $name })))
}

## Validate an Azure Table Storage table name (^[A-Za-z][A-Za-z0-9]{2,62}$):
## 3-63 alphanumeric chars, must begin with a letter, case-insensitive, "tables"
## reserved. Returns { name, valid, reason }.
fn Azure::valid_table_name ($name) {
    Azure::_decode("valid_table_name",
        azure__valid_table_name(to_json({ name => $name })))
}

## Validate a Cosmos DB resource id ($id — a database or container name): 1-255
## chars, may not contain "/" or "\" (the only chars the service forbids).
## Alphanumeric ASCII is recommended (not enforced). Returns { id, valid, reason }.
fn Azure::valid_cosmos_id ($id) {
    Azure::_decode("valid_cosmos_id", azure__valid_cosmos_id(to_json({ id => $id })))
}

## Validate an Azure GUID (the 8-4-4-4-12 hex form used for subscription, tenant,
## client, and object IDs). Hex is case-insensitive; braces are not accepted.
## Returns a hashref { guid, valid, reason } (reason undef when valid).
fn Azure::valid_guid ($guid) {
    Azure::_decode("valid_guid", azure__valid_guid(to_json({ guid => $guid })))
}

## Normalize a GUID to the canonical lowercase 8-4-4-4-12 form, accepting the
## formats Azure IDs arrive in: hyphenated, hyphenless (32 hex), or wrapped in
## braces {…} / parens (…). Returns a hashref { input, guid }; dies unless
## exactly 32 hex digits remain.
fn Azure::normalize_guid ($guid) {
    Azure::_decode("normalize_guid", azure__normalize_guid(to_json({ guid => $guid })))->{guid}
}

## Re-emit a GUID in a .NET Guid.ToString format specifier — the formatting
## companion of normalize_guid (which always gives the D form). Accepts any input
## format; $format is N (32 digits, no hyphens), D (hyphenated, default), B
## ({hyphenated}), or P ((hyphenated)), case-insensitive. Output hex is lowercase.
## Returns the formatted string.
fn Azure::format_guid ($guid, $format = "D") {
    Azure::_decode("format_guid", azure__format_guid(to_json({ guid => $guid, format => $format })))->{guid}
}
